# =============================================================================
# WHERE TO PUT SECRETS (read this first)
# =============================================================================
#
# 1) Copy this file to a new file named `.env` in the SAME folder as package.json:
#      PowerShell:  Copy-Item .env.example .env
#      mac/Linux:   cp .env.example .env
#
# 2) Open `.env` and paste values on the lines marked below (after the `=`).
#    Use ONE Gemini line (GEMINI_API_KEY or GOOGLE_GEMINI_API_KEY), not both.
#
# 3) Push to git: only code + `.env.example`. NEVER add or commit `.env`
#    (it is in .gitignore). Never paste keys into chat or into tracked files.
#
# Minimum to run AI intake + proposal features:
#   • GEMINI_API_KEY — from https://aistudio.google.com/apikey
#
# Minimum to sync catalog from Google Sheets:
#   • GOOGLE_SERVICE_ACCOUNT_FILE=./your-sa.json  OR  GOOGLE_SERVICE_ACCOUNT=...full JSON...
#   • Share the sheet with the service account email (Editor or Viewer).
#   • GOOGLE_SHEETS_SPREADSHEET_ID — your spreadsheet ID (already has a sample below).
#
# Optional: a service-account JSON file in the repo root can be named anything;
# `gen-lang-client-*.json` is gitignored if you keep it next to the app — still prefer
# not committing any credential files.
# =============================================================================

# App Settings
PORT=3000
NODE_ENV=development
# ESTIMATOR_DEBUG_PROJECT_AUTOFILL=1
# Optional: server logs [projectAutofill] when applying bid # / location defaults from project title.

# Address autocomplete (Project Intake) uses OpenStreetMap Nominatim from the server.
# Optional: set a contact URL/email in User-Agent per https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_USER_AGENT=CWA-Estimator/1.0 (https://your-site.example/contact)
# ADDRESS_SUGGEST_COUNTRY_CODES=us

# --- Database driver (Phase 5) ---
# sqlite (default). For Postgres: DB_DRIVER=pg and DATABASE_URL (Supabase pooler or local; see docker-compose.yml).
DB_DRIVER=sqlite
DATABASE_URL=

# --- Supabase (Vite + server; used with auth middleware / Storage) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=project-files
# When 1, /api/v1/* (except /health, /session) requires Supabase JWT
AUTH_REQUIRED=0


# Database — one shared SQLite file for the whole team (all users see the same projects).
# Relative paths resolve from process.cwd(). On production, mount a volume and point here, e.g.:
# DATABASE_PATH=/data/estimator.db
DATABASE_PATH=estimator.db

# Optional: Durable persistence for Cloud Run using GCS snapshot restore + periodic backups.
# This makes projects survive deploys even when the container filesystem is replaced.
# Requires the Cloud Run service account to have Storage object read/write on the bucket.
# DATABASE_GCS_BUCKET=your-bucket-name
# DATABASE_GCS_OBJECT=estimator.db
# DATABASE_GCS_BACKUP_INTERVAL_MS=30000
#
# Optional: Same pattern using Supabase Storage (takes precedence if DATABASE_SUPABASE_BUCKET is set).
# Create a private bucket in Supabase (Storage) and set:
#   SUPABASE_URL (or NEXT_PUBLIC_SUPABASE_URL) — project URL
#   SUPABASE_SERVICE_ROLE_KEY — service role (server only; never expose to the browser)
# DATABASE_SUPABASE_BUCKET=estimator-sqlite
# DATABASE_SUPABASE_OBJECT=estimator.db
# DATABASE_SUPABASE_BACKUP_INTERVAL_MS=30000

# AI Integration — PASTE: Google AI Studio API key (https://aistudio.google.com/apikey)
# Use either GEMINI_API_KEY or GOOGLE_GEMINI_API_KEY; leave the other blank.
# This is NOT a "browser" Maps key and NOT the Sheets service-account JSON.
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Google Sheets Sync (catalog ITEMS / MODIFIERS / BUNDLES)
# Requires a Google Cloud *service account* JSON (IAM → Service accounts → Keys → JSON).
# The JSON must include "type": "service_account", "client_email", and "private_key".
# This is NOT the same as GEMINI_API_KEY or a “gen-lang-client” API key — though a file
# downloaded for a service account in that project is valid if it has the fields above.
#
# Share the target spreadsheet with the service account email (Viewer is enough for sync-in).
#
# Use ONE auth method (leave the others empty).
#
# 1) Inline JSON (production / Cloud Run Secret — paste entire JSON as one line or use multiline in your host)
GOOGLE_SERVICE_ACCOUNT=
#
# 1b) Same JSON file contents, base64-encoded single line (when your host breaks multiline JSON secrets)
GOOGLE_SERVICE_ACCOUNT_BASE64=
#
# 2) Path to the JSON file — PASTE path after = e.g. ./google-service-account.json
#    File must be service account JSON with "type": "service_account", client_email, private_key.
GOOGLE_SERVICE_ACCOUNT_FILE=
#
# 3) Standard Google env (same file as #2; optional duplicate — either works)
GOOGLE_APPLICATION_CREDENTIALS=
#
# 4) Split env vars (private key use \n for newlines when pasting in a single line)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# To generate a clean PEM for GCP "paste key" UIs: npm run extract-sa-pem -- path/to/sa.json > sa.pem (do not commit sa.pem)
# Cloud Run: set GOOGLE_SHEETS_AUTH_DEBUG=1 temporarily; logs show private_key_sha256_16 — compare to:
#   node scripts/extract-service-account-pem.mjs --fingerprint path/to/sa.json

# Spreadsheet and tab config
GOOGLE_SHEETS_SPREADSHEET_ID=1QWCGCssWtAQ8Pjx9_-7LDs4lraRbptURd8D04bNvnEg
GOOGLE_SHEETS_TAB_ITEMS=CLEAN_ITEMS
GOOGLE_SHEETS_TAB_MODIFIERS=MODIFIERS
GOOGLE_SHEETS_TAB_BUNDLES=BUNDLES

# Catalog sync behavior (SQLite + Google Sheet)
# Default: merge mode — sheet rows upsert in place; bulk-imported items stay active. Only stale sheet-item-* / sheet-mod-* / sheet-bundle-* rows are deactivated.
# Set to 1 for legacy “sheet is full truth”: first imported row deactivates entire table, then sheet rows reactivate.
# CATALOG_SYNC_REPLACE_MODE=1
# After the HTTP server starts, run one Sheets pull (same as POST sync-catalog). Errors are logged only.
# AUTO_SYNC_CATALOG_ON_START=1

# Cloud Natural Language API (entity analysis for intake metadata — fills gaps after Gemini)
# Enable the API on the same GCP project as the service account; scope uses cloud-platform.
# GOOGLE_NATURAL_LANGUAGE_ENABLED=1

# Maps Grounding Lite (MCP at mapstools.googleapis.com) — refines job site address after Gemini + NLP.
# Enable "Maps Grounding Lite API" on your GCP project and create a Maps API key with that API enabled.
# This is NOT the Gemini key — use a Google Maps Platform key (X-Goog-Api-Key on the MCP server).
# GOOGLE_MAPS_GROUNDING_ENABLED=1
# GOOGLE_MAPS_GROUNDING_API_KEY=
# Optional: override model for the grounding-only follow-up call (defaults to INTAKE_GEMINI_MODEL / gemini-2.5-flash).
# GOOGLE_MAPS_GROUNDING_MODEL=

# PDF intake — Document AI (optional; default is local pdf-parse + fallback-text)
# In GCP: enable "Document AI API", create a processor in region us, copy the processor ID.
# The Node client uses Application Default Credentials — same idea as Sheets:
#   GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account.json
# Grant that service account "Document AI API User" (or Editor on the project).
# UPLOAD_PDF_PROVIDER=fallback-text
# UPLOAD_PDF_PROVIDER=google-document-ai
# GOOGLE_CLOUD_PROJECT_ID=
# DOCUMENT_AI_PROCESSOR_ID=
# (If you already set GOOGLE_APPLICATION_CREDENTIALS for Sheets, you can reuse it.)

# Backward-compatible legacy keys
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=

# Supabase (browser + optional Express session middleware) — see utils/supabase/*.ts
# Copy values from the Supabase dashboard (Project Settings → API). This app is Vite + Express, not Next.js.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
