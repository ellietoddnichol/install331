# App Settings
PORT=3000
NODE_ENV=development

# Address autocomplete (Project Intake) uses OpenStreetMap Nominatim from the server.
# Optional: set a contact URL/email in User-Agent per https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_USER_AGENT=CWA-Estimator/1.0 (https://your-site.example/contact)
# ADDRESS_SUGGEST_COUNTRY_CODES=us

# Database — one shared SQLite file for the whole team (all users see the same projects).
# Relative paths resolve from process.cwd(). On production, mount a volume and point here, e.g.:
# DATABASE_PATH=/data/estimator.db
DATABASE_URL=estimator.db

# AI Integration
# Note: This is an API key from Google AI Studio/Vertex for Gemini models.
# A Google service account JSON does NOT replace this key.
GEMINI_API_KEY=
# Alternate key name is also supported
GOOGLE_GEMINI_API_KEY=

# Google Sheets Sync (catalog ITEMS / MODIFIERS / BUNDLES)
# Requires a Google Cloud *service account* JSON (IAM → Service accounts → Keys → JSON).
# The JSON must include "type": "service_account", "client_email", and "private_key".
# This is NOT the same as GEMINI_API_KEY or a “gen-lang-client” API key — though a file
# downloaded for a service account in that project is valid if it has the fields above.
#
# Share the target spreadsheet with the service account email (Viewer is enough for sync-in).
#
# Use ONE auth method (leave the others empty).
#
# 1) Inline JSON (production / Cloud Run Secret — paste entire JSON as one line or use multiline in your host)
GOOGLE_SERVICE_ACCOUNT=
#
# 1b) Same JSON file contents, base64-encoded single line (when your host breaks multiline JSON secrets)
GOOGLE_SERVICE_ACCOUNT_BASE64=
#
# 2) Path to the JSON file — resolved against process.cwd() AND the repo root (so ./file.json works from any cwd)
GOOGLE_SERVICE_ACCOUNT_FILE=
#
# 3) Standard Google env (same file as #2; optional duplicate — either works)
GOOGLE_APPLICATION_CREDENTIALS=
#
# 4) Split env vars (private key use \n for newlines when pasting in a single line)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# To generate a clean PEM for GCP "paste key" UIs: npm run extract-sa-pem -- path/to/sa.json > sa.pem (do not commit sa.pem)
# Cloud Run: set GOOGLE_SHEETS_AUTH_DEBUG=1 temporarily; logs show private_key_sha256_16 — compare to:
#   node scripts/extract-service-account-pem.mjs --fingerprint path/to/sa.json

# Spreadsheet and tab config
GOOGLE_SHEETS_SPREADSHEET_ID=1QWCGCssWtAQ8Pjx9_-7LDs4lraRbptURd8D04bNvnEg
GOOGLE_SHEETS_TAB_ITEMS=ITEMS
GOOGLE_SHEETS_TAB_MODIFIERS=MODIFIERS
GOOGLE_SHEETS_TAB_BUNDLES=BUNDLES

# Cloud Natural Language API (entity analysis for intake metadata — fills gaps after Gemini)
# Enable the API on the same GCP project as the service account; scope uses cloud-platform.
# GOOGLE_NATURAL_LANGUAGE_ENABLED=1

# Maps Grounding Lite (MCP at mapstools.googleapis.com) — refines job site address after Gemini + NLP.
# Enable "Maps Grounding Lite API" on your GCP project and create a Maps API key with that API enabled.
# This is NOT the Gemini key — use a Google Maps Platform key (X-Goog-Api-Key on the MCP server).
# GOOGLE_MAPS_GROUNDING_ENABLED=1
# GOOGLE_MAPS_GROUNDING_API_KEY=
# Optional: override model for the grounding-only follow-up call (defaults to INTAKE_GEMINI_MODEL / gemini-2.5-flash).
# GOOGLE_MAPS_GROUNDING_MODEL=

# Backward-compatible legacy keys
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=
