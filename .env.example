# App Settings
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=estimator.db

# AI Integration
# Note: This is an API key from Google AI Studio/Vertex for Gemini models.
# A Google service account JSON does NOT replace this key.
GEMINI_API_KEY=
# Alternate key name is also supported
GOOGLE_GEMINI_API_KEY=

# Google Sheets Sync (catalog ITEMS / MODIFIERS / BUNDLES)
# Requires a Google Cloud *service account* JSON (IAM → Service accounts → Keys → JSON).
# The JSON must include "type": "service_account", "client_email", and "private_key".
# This is NOT the same as GEMINI_API_KEY or a “gen-lang-client” API key — though a file
# downloaded for a service account in that project is valid if it has the fields above.
#
# Share the target spreadsheet with the service account email (Viewer is enough for sync-in).
#
# Use ONE auth method (leave the others empty).
#
# 1) Inline JSON (production / Cloud Run Secret — paste entire JSON as one line or use multiline in your host)
GOOGLE_SERVICE_ACCOUNT=
#
# 1b) Same JSON file contents, base64-encoded single line (when your host breaks multiline JSON secrets)
GOOGLE_SERVICE_ACCOUNT_BASE64=
#
# 2) Path to the JSON file — resolved against process.cwd() AND the repo root (so ./file.json works from any cwd)
GOOGLE_SERVICE_ACCOUNT_FILE=
#
# 3) Standard Google env (same file as #2; optional duplicate — either works)
GOOGLE_APPLICATION_CREDENTIALS=
#
# 4) Split env vars (private key use \n for newlines when pasting in a single line)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# To generate a clean PEM for GCP "paste key" UIs: npm run extract-sa-pem -- path/to/sa.json > sa.pem (do not commit sa.pem)

# Spreadsheet and tab config
GOOGLE_SHEETS_SPREADSHEET_ID=1QWCGCssWtAQ8Pjx9_-7LDs4lraRbptURd8D04bNvnEg
GOOGLE_SHEETS_TAB_ITEMS=ITEMS
GOOGLE_SHEETS_TAB_MODIFIERS=MODIFIERS
GOOGLE_SHEETS_TAB_BUNDLES=BUNDLES

# Backward-compatible legacy keys
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=
