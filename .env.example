# App Settings
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=estimator.db

# AI Integration
# Note: This is an API key from Google AI Studio/Vertex for Gemini models.
# A Google service account JSON does NOT replace this key.
GEMINI_API_KEY=
# Alternate key name is also supported
GOOGLE_GEMINI_API_KEY=

# Google Sheets Sync
# Preferred local setup: store the service-account JSON as
# ./google-service-account.json and point GOOGLE_SERVICE_ACCOUNT_FILE at it.
# Use ONE auth method below:
# 1) Full JSON in a single env var (fallback)
GOOGLE_SERVICE_ACCOUNT=
# 2) Service account file path (recommended)
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json
# 3) Split credentials (fallback)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Spreadsheet and tab config
GOOGLE_SHEETS_SPREADSHEET_ID=1QWCGCssWtAQ8Pjx9_-7LDs4lraRbptURd8D04bNvnEg
GOOGLE_SHEETS_TAB_ITEMS=ITEMS
GOOGLE_SHEETS_TAB_MODIFIERS=MODIFIERS
GOOGLE_SHEETS_TAB_BUNDLES=BUNDLES

# Backward-compatible legacy keys
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=
